### FastAPI Application with Path Operation Tags

Source: https://github.com/fastapi/fastapi/blob/master/docs/en/docs/advanced/generate-clients.md

This example demonstrates a FastAPI application where path operations are organized using tags, allowing for better categorization in the generated OpenAPI documentation and client SDKs.

```python
from typing import Union

from fastapi import FastAPI, Depends
from pydantic import BaseModel


class Item(BaseModel):
    name: str
    price: float
    is_offer: Union[bool, None] = None


class ResponseMessage(BaseModel):
    message: str


app = FastAPI()


async def common_parameters(q: Union[str, None] = None, skip: int = 0, limit: int = 100):
    return {"q": q, "skip": skip, "limit": limit}


@app.get("/items/", tags=["items"])
async def read_items(commons: dict = Depends(common_parameters)):
    return commons


@app.get("/users/", tags=["users"])
async def read_users(commons: dict = Depends(common_parameters)):
    return commons


@app.get("/items/{item_id}", response_model=Item, tags=["items"])
def read_item(item_id: str, q: Union[str, None] = None):
    return {"id": "foo", "name": "Foo", "price": 42.0}


@app.put("/items/{item_id}", response_model=ResponseMessage, tags=["items"])
def update_item(item_id: str, item: Item):
